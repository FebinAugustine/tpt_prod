# ============================================
# Production Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# Domain Configuration
DOMAIN_NAME=thepowertrainer.cloud

# Let's Encrypt SSL
LETSENCRYPT_EMAIL=supporttpt@gmail.com


# MongoDB Configuration (Docker/MongoDB container credentials)
MONGO_ROOT_USER=tpt_admin
MONGO_ROOT_PASSWORD=your_secure_mongodb_password_here

# Backend Database Connection (NestJS uses this)
MONGODB_URI=mongodb://tpt_admin:your_secure_mongodb_password_here@mongodb:27017/tptappdb?authSource=admin

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_secure_jwt_secret_here
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay Configuration
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Gmail App Password)
SMTP_PASSWORD=your_app_password
SMTP_USER=support@thepowertrainer.cloud
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=support@thepowertrainer.cloud

# Frontend/Backend URLs
FRONTEND_URL=https://thepowertrainer.cloud
CORS_ORIGINS=https://thepowertrainer.cloud,https://www.thepowertrainer.cloud
NEXT_PUBLIC_API_URL=https://api.thepowertrainer.cloud/api/v1

# Logging
LOG_LEVEL=info
LOG_CONSOLE_ENABLED=true