# ============================================
# Development Environment Configuration
# Copy this to .env.dev — used by docker-compose.yml (the dev/default file).
# Every value has a safe default baked into docker-compose.yml already, so
# this file only needs to override what you actually care about (e.g. real
# Cloudinary/Razorpay keys if you want those integrations to work locally).
# ============================================

MONGO_ROOT_USER=tpt_admin
MONGO_ROOT_PASSWORD=devpassword

REDIS_PASSWORD=devpassword

JWT_SECRET=dev_jwt_secret_change_me
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me

# Optional — leave blank to skip these integrations in dev
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
