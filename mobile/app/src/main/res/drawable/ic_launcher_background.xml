<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background (API 26+) — protein/gym-themed rebrand
  (2026-07-23), replacing the unmodified Android Studio template default
  (grid-line placeholder + Android green). Diagonal brand-green gradient
  (Green #22B14C -> GreenDark #178C3B, matches :core:designsystem's
  theme/Color.kt), paired with ic_launcher_foreground.xml's white dumbbell.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="10"
                android:startY="10"
                android:endX="98"
                android:endY="98"
                android:type="linear">
                <item android:color="#FF22B14C" android:offset="0.0" />
                <item android:color="#FF178C3B" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
